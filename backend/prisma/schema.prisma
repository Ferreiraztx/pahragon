generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  nome      String
  email     String    @unique
  cpf       String?
  senha     String
  telefone  String?
  dataNascimento DateTime?
  cep         String?
  rua         String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Admin {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String
}

model Court {
  id           Int       @id @default(autoincrement())
  nome         String
  descricao    String?
  precoPorHora Float
  bookings     Booking[]
}

model Booking {
  id         Int      @id @default(autoincrement())
  user       User?     @relation(fields: [userId], references: [id])
  userId     Int?
  nomeAvulso String?
  court      Court    @relation(fields: [courtId], references: [id])
  courtId    Int
  data       DateTime
  horaInicio DateTime
  horaFim    DateTime
  status     String   @default("pendente")
  createdAt  DateTime @default(now())
  payment    Payment?

  bloqueios BloqueioQuadra[]
}

model Payment {
  id        Int     @id @default(autoincrement())
  booking   Booking @relation(fields: [bookingId], references: [id])
  bookingId Int     @unique
  valor     Float
  metodo    String
  status    String  @default("pendente")
  gatewayId String?
}

model Tournament {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String?
  data        DateTime
  dataFim     DateTime
  vagas       Int
  preco       Float
  status      String   @default("aberto")
  createdAt   DateTime @default(now())
  whatsapp    String?
  quadras     String[]
}

model HorarioFuncionamento {
  id             Int      @id @default(autoincrement())
  diaSemana      Int      @unique // 0 = Domingo ... 6 = Sábado
  ativo          Boolean  @default(true)
  horaAbertura   String   @default("08:00") // "HH:mm"
  horaFechamento String   @default("23:00") // "HH:mm"
  updatedAt      DateTime @updatedAt
}
model BloqueioQuadra {
  id          Int      @id @default(autoincrement())
  quadraId    Int
  data        String   // Salva no formato "YYYY-MM-DD" para evitar fuso horário
  horaInicio  String   // Ex: "08:00"
  horaFim     String   // Ex: "12:00"
  motivo      String?  // Ex: "Manutenção da Areia"
  
  quadra      Booking   @relation(fields: [quadraId], references: [id])
}